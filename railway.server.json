{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install --frozen-lockfile && bun run --filter server build"
  },
  "deploy": {
    "preDeployCommand": "bun run --filter @test-evals/db db:push",
    "startCommand": "bun --cwd apps/server start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/",
    "healthcheckTimeout": 30
  }
}
